generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id          String   @id @default(uuid())
  fullName    String
  email       String
  phoneNumber String
  subject     String
  message     String
  createdAt   DateTime @default(now())
}
